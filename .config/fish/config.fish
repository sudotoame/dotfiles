if status is-interactive
    # Commands to run in interactive sessions can go here
    alias ls 'eza --icons'
    alias ll 'eza --icons -l'
    alias la 'eza --icons -la'
    alias gis 'git status'
    alias gia 'git add'
    alias gic 'git commit'
    alias gip 'git push'
    alias pls 'sudo dnf'
    alias v nvim
end
